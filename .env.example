DATABASE_URL="postgresql://user:password@host:6543/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

ADMIN_EMAIL=admin@astrology.com
ADMIN_PASSWORD=

HOME=

# Payment — Cashfree
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# Google Places API (city search)
GOOGLE_PLACES_API_KEY=

# ─── Email — Gmail SMTP via Nodemailer ─────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to: myaccount.google.com → Security → 2-Step Verification → App Passwords
# 3. Create an App Password for "Mail" — paste the 16-character code below
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Google Calendar / Google Meet (OAuth2) ────────────────────────────────────
# 1. console.cloud.google.com → APIs & Services → OAuth consent screen
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#    → Type: Web Application → Add redirect URI below → Copy Client ID & Secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/admin/google-auth/callback
GOOGLE_HOST_EMAIL=
# GOOGLE_REFRESH_TOKEN is stored in the database (AppSettings table) after
# connecting Google Calendar in the Admin Dashboard. Do not set it here.
